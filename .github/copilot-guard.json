{
  "allowed_file_globs": [
    "Connections/sample_connection.yaml",
    "Connections/sample_connection.md",
    "queries/sample_query.yaml"
  ],
  "blocked_file_globs": [
    "Connections/*.yaml",
    "Connections/*.yml",
    "Connections/*.md"
  ],
  "blocked_content_patterns": [
    {
      "pattern": "Data Source=powerbi://api\\.powerbi\\.com/v1\\.0/myorg/(?!SampleWorkspace\\b|YourWorkspace\\b)",
      "reason": "Potential real Power BI workspace URI detected"
    },
    {
      "pattern": "C:\\\\\\\\Users\\\\\\\\(?![^\\\\]+\\\\\\\\dax-query-mcp\\\\\\\\?$)(?!absolute\\\\\\\\path\\\\\\\\to)",
      "reason": "Concrete local Windows path detected"
    }
  ]
}
